@startuml c4-code-class
title Class Diagram - AI Service Module

interface AiService {
    +generateResponse(sessionId: UUID, userMessage: String): ChatResponse
    +analyzeThought(automaticThought: String): List<DistortionSuggestion>
    +generateReframingPrompts(thought: String, distortionIds: List<String>): List<String>
    +detectCrisis(text: String): CrisisDetectionResultDto
    +generateInsights(userId: UUID): DiaryInsights
    +summarizeSession(sessionId: UUID): SessionSummary
}

class AiServiceImpl {
    -llmClient: LlmClient
    -ragContextBuilder: RagContextBuilder
    -crisisDetector: CrisisDetector
    -userSessionRepository: UserSessionRepository
    -diaryEntryRepository: DiaryEntryRepository
    -cognitiveDistortionRepository: CognitiveDistortionRepository
    -chatMessageRepository: ChatMessageRepository
}

interface LlmClient {
    +chat(systemPrompt: String, userMessage: String): String
    +chat(systemPrompt: String, history: List<Message>): String
}

class AnthropicClient {
    -apiKey: String
    -model: String
    -maxTokens: int
    -temperature: double
    -restTemplate: RestTemplate
}

class RagContextBuilder {
    -vectorStore: SimpleVectorStore
    -embeddingService: EmbeddingService
    -sessionRepository: UserSessionRepository
    -diaryRepository: DiaryEntryRepository
    +buildContext(userId: UUID, sessionId: UUID, query: String): String
}

class SimpleVectorStore {
    -vectors: Map<String, float[]>
    -documents: Map<String, Document>
    +addDocument(id: String, doc: Document, embedding: float[]): void
    +similaritySearch(queryEmbedding: float[], topK: int): List<Document>
    -cosineSimilarity(a: float[], b: float[]): double
}

class EmbeddingService {
    -embeddingDimension: int
    +embed(text: String): float[]
}

class CrisisDetector {
    -{static} CRISIS_KEYWORDS: Set<String>
    -llmClient: LlmClient
    +analyze(text: String): CrisisDetectionResultDto
    -performAiAnalysis(text: String): RiskLevel
    -combineRiskAssessments(keywords: List<String>, aiRisk: RiskLevel): RiskLevel
    -determineAction(risk: RiskLevel): RecommendedAction
}

class Document {
    -id: String
    -content: String
    -metadata: Map<String, String>
}

class KnowledgeBaseLoader {
    -vectorStore: SimpleVectorStore
    -embeddingService: EmbeddingService
    +loadKnowledgeBase(): void
}

AiService <|.. AiServiceImpl
LlmClient <|.. AnthropicClient
AiServiceImpl --> LlmClient : uses
AiServiceImpl --> RagContextBuilder : uses
AiServiceImpl --> CrisisDetector : uses
RagContextBuilder --> SimpleVectorStore : queries
RagContextBuilder --> EmbeddingService : embeds text
SimpleVectorStore --> Document : stores
CrisisDetector --> LlmClient : uses for AI analysis
KnowledgeBaseLoader --> SimpleVectorStore : loads documents into
KnowledgeBaseLoader --> EmbeddingService : generates embeddings

@enduml


@startuml c4-code-sequence-chat
title Sequence Diagram - Chat Message Flow

actor User
participant "CLI Client" as CLI
participant "SessionController" as SC
participant "SessionService" as SS
participant "AiService" as AI
participant "RagContextBuilder" as RAG
participant "SimpleVectorStore" as VS
participant "LlmClient" as LLM
participant "CrisisDetector" as CD
participant "ChatMessageRepository" as CMR
database "H2 Database" as DB

User -> CLI: Enter message
CLI -> SC: POST /sessions/{id}/chat
SC -> SS: chat(sessionId, message)

SS -> CMR: save(userMessage)
CMR -> DB: INSERT chat_message

SS -> AI: generateResponse(sessionId, message)
AI -> RAG: buildContext(userId, sessionId, message)

RAG -> VS: similaritySearch(embedding, 3)
VS --> RAG: relevant CBT documents

RAG -> DB: Query recent sessions
RAG -> DB: Query recent diary entries
RAG -> DB: Query session transcript
RAG --> AI: assembled context

AI -> LLM: chat(systemPrompt + context, message)
LLM --> AI: AI response text

AI -> CD: analyze(userMessage)
CD --> AI: CrisisDetectionResult

AI --> SS: ChatResponse

SS -> CMR: save(assistantMessage)
CMR -> DB: INSERT chat_message

SS --> SC: ChatResponse
SC --> CLI: JSON response
CLI --> User: Display response

@enduml


@startuml c4-code-sequence-diary
title Sequence Diagram - Diary Entry with AI Analysis

actor User
participant "CLI Client" as CLI
participant "DiaryController" as DC
participant "DiaryService" as DS
participant "AiService" as AI
participant "LlmClient" as LLM
participant "CognitiveDistortionRepo" as CDR
participant "DiaryEntryRepository" as DER
database "H2 Database" as DB

User -> CLI: Create new diary entry
CLI -> CLI: Prompt for situation,\nthought, emotions, mood

CLI -> DC: POST /diary/distortions/suggest
DC -> DS: suggestDistortions(thought)
DS -> AI: analyzeThought(thought)

AI -> CDR: findAll()
CDR -> DB: SELECT distortions
CDR --> AI: all distortions

AI -> LLM: chat(analysisPrompt, thought)
LLM --> AI: JSON distortion analysis

AI --> DS: List<DistortionSuggestion>
DS --> DC: List<DistortionSuggestion>
DC --> CLI: JSON suggestions
CLI --> User: Display suggested distortions

User -> CLI: Confirm distortions,\nadd alternative thought

CLI -> DC: POST /diary/entries
DC -> DS: createEntry(userId, request)

DS -> CDR: findAllById(distortionIds)
CDR -> DB: SELECT distortions
CDR --> DS: distortion entities

DS -> DER: save(diaryEntry)
DER -> DB: INSERT diary_entry
DER --> DS: saved entry

DS --> DC: DiaryEntryResponse
DC --> CLI: JSON response
CLI --> User: Entry saved confirmation

@enduml
