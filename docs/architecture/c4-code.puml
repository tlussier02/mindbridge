@startuml c4-code-class
title Class Diagram - AI Service Module

interface AiService {
    +generateResponse(sessionId: UUID, userMessage: String): ChatResponse
    +analyzeThought(automaticThought: String): List<DistortionSuggestion>
    +generateReframingPrompts(thought: String, distortionIds: List<String>): List<String>
    +detectCrisis(text: String): CrisisDetectionResultDto
    +generateInsights(userId: UUID): DiaryInsights
    +summarizeSession(sessionId: UUID): SessionSummary
}

class AiServiceImpl {
    -llmClient: LlmClient
    -ragContextBuilder: RagContextBuilder
    -crisisDetector: CrisisDetector
    -userSessionRepository: UserSessionRepository
    -diaryEntryRepository: DiaryEntryRepository
    -cognitiveDistortionRepository: CognitiveDistortionRepository
    -chatMessageRepository: ChatMessageRepository
}

interface LlmClient {
    +chat(systemPrompt: String, userMessage: String): String
    +chat(systemPrompt: String, history: List<Message>): String
}

class AnthropicClient {
    -apiKey: String
    -model: String
    -maxTokens: int
    -temperature: double
    -restTemplate: RestTemplate
}

class RagContextBuilder {
    -vectorStore: SimpleVectorStore
    -embeddingService: EmbeddingService
    -sessionRepository: UserSessionRepository
    -diaryRepository: DiaryEntryRepository
    +buildContext(userId: UUID, sessionId: UUID, query: String): String
}

class SimpleVectorStore {
    -vectors: Map<String, float[]>
    -documents: Map<String, Document>
    +addDocument(id: String, doc: Document, embedding: float[]): void
    +similaritySearch(queryEmbedding: float[], topK: int): List<Document>
    -cosineSimilarity(a: float[], b: float[]): double
}

class EmbeddingService {
    -embeddingDimension: int
    +embed(text: String): float[]
}

class CrisisDetector {
    -{static} CRISIS_KEYWORDS: Set<String>
    -llmClient: LlmClient
    +analyze(text: String): CrisisDetectionResultDto
    -performAiAnalysis(text: String): RiskLevel
    -combineRiskAssessments(keywords: List<String>, aiRisk: RiskLevel): RiskLevel
    -determineAction(risk: RiskLevel): RecommendedAction
}

class Document {
    -id: String
    -content: String
    -metadata: Map<String, String>
}

class KnowledgeBaseLoader {
    -vectorStore: SimpleVectorStore
    -embeddingService: EmbeddingService
    +loadKnowledgeBase(): void
}

AiService <|.. AiServiceImpl
LlmClient <|.. AnthropicClient
AiServiceImpl --> LlmClient : uses
AiServiceImpl --> RagContextBuilder : uses
AiServiceImpl --> CrisisDetector : uses
RagContextBuilder --> SimpleVectorStore : queries
RagContextBuilder --> EmbeddingService : embeds text
SimpleVectorStore --> Document : stores
CrisisDetector --> LlmClient : uses for AI analysis
KnowledgeBaseLoader --> SimpleVectorStore : loads documents into
KnowledgeBaseLoader --> EmbeddingService : generates embeddings

@enduml


