@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Container Diagram - MindBridge

Person(patient, "Patient", "Primary user seeking burnout recovery")
Person(therapist, "Therapist", "Monitors patient progress")

System_Boundary(dta, "MindBridge") {
    Container(frontend, "Web Frontend", "Next.js / React", "Browser-based interface for authentication, sessions, diary, progress, and crisis support")
    Container(api, "Spring Boot Application", "Java 21, Spring Boot 4.0", "Provides REST API, business logic, security, AI integration, and MCP endpoints")
    ContainerDb(h2db, "H2 Database", "H2 (File-based)", "Stores users, sessions, diary entries, chat messages, and cognitive distortions")
    Container(vectorstore, "SimpleVector Store", "Java, In-Memory", "Vector storage for RAG similarity search using cosine similarity")
    Container(kb, "Knowledge Base", "JSON Files", "CBT reference materials: distortions, techniques, crisis protocols")
}

System_Ext(llm, "LLM Provider", "Anthropic Claude API")

Rel(patient, frontend, "Uses via", "Browser")
Rel(frontend, api, "Calls REST endpoints", "HTTPS/JSON")
Rel(therapist, api, "Monitors progress via", "HTTPS/JSON")

Rel(api, h2db, "Reads/writes data", "JPA/JDBC")
Rel(api, vectorstore, "Stores and queries embeddings", "Java API")
Rel(api, kb, "Loads CBT reference content", "File I/O")
Rel(vectorstore, kb, "Indexes content from", "Embeddings")
Rel(api, llm, "Sends prompts, receives responses", "HTTPS/REST")

@enduml
